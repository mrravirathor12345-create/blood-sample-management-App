# Blood Sample Management System - AI API Keys
# Copy this file to .env and fill in your actual API keys

# Google Gemini AI Key (for clinical analysis)
# Get your key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Groq AI Key (for fast inference)
# Get your key from: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# AI Engine to use (gemini or groq)
VITE_AI_ENGINE=gemini

# Important Notes:
# - Never commit your actual .env file to version control
# - Keys are also configurable in-app via Settings panel
# - The app falls back to local analysis if no API key is configured
